<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <input>
        <net-file   value="network.net.xml"/>
        <route-files value="routes.rou.xml"/>
    </input>
    <time>
        <begin value="0"/>
        <end   value="300"/>
        <step-length value="0.5"/>
    </time>
    <processing>
        <ignore-route-errors value="true"/>
    </processing>
    <report>
        <no-step-log value="true"/>
        <verbose value="false"/>
    </report>
</configuration>